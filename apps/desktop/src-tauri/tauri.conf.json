{
  "productName": "AgentMux",
  "version": "0.1.1",
  "identifier": "dev.agentmux.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AgentMux",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 560,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/agentmux",
      "binaries/cmux"
    ],
    "resources": {
      "../dist": "dist"
    },
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
